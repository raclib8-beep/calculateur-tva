<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Calcul Heures Supplémentaires</title>

<style>
body{font-family:Arial,sans-serif;background:#f5f5f5;padding:20px;}
.container{max-width:500px;margin:auto;background:white;padding:20px;border-radius:10px;box-shadow:0 2px 8px rgba(0,0,0,.2);}
h2{text-align:center;color:#0b7dda;}
input,button{width:100%;padding:12px;margin:10px 0;font-size:18px;box-sizing:border-box;}
button{background:#0b7dda;color:white;border:none;border-radius:6px;}
#resultat{margin-top:15px;font-size:20px;font-weight:bold;}
a{display:block;margin-top:20px;text-align:center;text-decoration:none;color:#0b7dda;}
</style>
</head>
<body>

<div class="container">

<h2>Calcul Heures Supplémentaires</h2>

<input type="number" id="salaire" placeholder="Salaire mensuel (DH)">
<input type="number" id="heures" placeholder="Nombre d'heures supplémentaires">

<button onclick="calculer()">Calculer</button>

<div id="resultat"></div>

<a href="index.html">⬅ Retour à l'accueil</a>

</div>

<script>
function calculer(){

let salaire=parseFloat(document.getElementById("salaire").value);
let heures=parseFloat(document.getElementById("heures").value);

if(isNaN(salaire)||isNaN(heures)){
document.getElementById("resultat").innerHTML="Veuillez remplir tous les champs.";
return;
}

let tauxHoraire=salaire/191;
let montant=heures*tauxHoraire*1.25;

document.getElementById("resultat").innerHTML=
"Montant estimé : <br><strong>"+montant.toFixed(2)+" DH</strong>";

}
</script>

</body>
</html>
